**/archive/

# Generated SDK output: committed only by CI via `git add -f`, never tracked locally.
# Local regeneration (testing) stays invisible to git, merges, and commits.
/sdk/v*/
/admin-sdk/v*/

__pycache__/
*.pyc
.pytest_cache/

# JavaScript/Node dependencies
node_modules/
package-lock.json

# PHP dependencies
vendor/
composer.lock

# Local npm auth — must never be committed
.npmrc
**/.npmrc
