{
    "name": "oauth-library/php-sdk",
    "description": "OAuth 2.0 PHP SDK",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "OAuthSdk\\": "src/"
        },
        "files": [
            "src/Types.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "OAuthSdk\\Tests\\": "tests/"
        }
    }
}
